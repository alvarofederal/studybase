// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────────────────────
// MATÉRIA — ex: "Atualidades do Mercado Financeiro"
// ─────────────────────────────────────────────
model Materia {
  id        String   @id @default(cuid())
  nome      String
  slug      String   @unique
  descricao String?  @db.Text
  icone     String?
  cor       String?
  ativa     Boolean  @default(true)
  ordem     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blocos       Bloco[]
  userMaterias UserMateria[]
  solicitacoes SolicitacaoMateria[]

  @@map("materias")
}

// ─────────────────────────────────────────────
// BLOCO — agrupa tópicos dentro de uma matéria
// ─────────────────────────────────────────────
model Bloco {
  id        String   @id @default(cuid())
  nome      String
  slug      String
  descricao String?  @db.Text
  ordem     Int      @default(0)
  materiaId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  materia Materia  @relation(fields: [materiaId], references: [id], onDelete: Cascade)
  topicos Topico[]

  @@unique([materiaId, slug])
  @@map("blocos")
}

// ─────────────────────────────────────────────
// TÓPICO — conteúdo de estudo
// ─────────────────────────────────────────────
model Topico {
  id        String   @id @default(cuid())
  titulo    String
  slug      String
  conteudo  String   @db.LongText
  resumo    String?  @db.Text
  ordem     Int      @default(0)
  blocoId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bloco      Bloco       @relation(fields: [blocoId], references: [id], onDelete: Cascade)
  quizzes    Quiz[]
  flashcards Flashcard[]

  @@unique([blocoId, slug])
  @@map("topicos")
}

// ─────────────────────────────────────────────
// QUIZ — pergunta de múltipla escolha
// ─────────────────────────────────────────────
model Quiz {
  id         String   @id @default(cuid())
  pergunta   String   @db.Text
  explicacao String?  @db.Text
  ordem      Int      @default(0)
  topicoId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  topico    Topico         @relation(fields: [topicoId], references: [id], onDelete: Cascade)
  opcoes    OpcaoQuiz[]
  respostas RespostaQuiz[]

  @@map("quizzes")
}

// ─────────────────────────────────────────────
// OPÇÃO DE QUIZ
// ─────────────────────────────────────────────
model OpcaoQuiz {
  id      String  @id @default(cuid())
  texto   String  @db.Text
  correta Boolean @default(false)
  ordem   Int     @default(0)
  quizId  String

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("opcoes_quiz")
}

// ─────────────────────────────────────────────
// FLASHCARD — frente e verso para revisão
// ─────────────────────────────────────────────
model Flashcard {
  id        String   @id @default(cuid())
  frente    String   @db.Text
  verso     String   @db.LongText
  dica      String?  @db.Text
  ordem     Int      @default(0)
  topicoId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topico   Topico             @relation(fields: [topicoId], references: [id], onDelete: Cascade)
  revisoes RevisaoFlashcard[]

  @@map("flashcards")
}

// ─────────────────────────────────────────────
// USER — autenticação e controle de acesso
// ─────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senha     String   // bcrypt hash
  role      Role     @default(USER)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]
  materias             UserMateria[]
  solicitacoes         SolicitacaoMateria[]
  respostasQuiz        RespostaQuiz[]
  revisoesFlashcard    RevisaoFlashcard[]

  @@map("users")
}

enum Role {
  ADMIN
  USER
}

// ─────────────────────────────────────────────
// REFRESH TOKEN — sessões JWT (7 dias)
// ─────────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique // SHA-256 do token raw
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// PASSWORD RESET TOKEN — recuperação de senha
// ─────────────────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usado     Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// USER MATERIA — quais matérias o usuário pode acessar
// ─────────────────────────────────────────────
model UserMateria {
  id        String    @id @default(cuid())
  userId    String
  materiaId String
  expiresAt DateTime?           // null = legado sem expiração; novo padrão: +30 dias
  createdAt DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  materia Materia @relation(fields: [materiaId], references: [id], onDelete: Cascade)

  @@unique([userId, materiaId])
  @@map("user_materias")
}

// ─────────────────────────────────────────────
// SOLICITAÇÃO DE ACESSO — usuário pede permissão para uma matéria
// ─────────────────────────────────────────────
model SolicitacaoMateria {
  id        String             @id @default(cuid())
  userId    String
  materiaId String
  status    StatusSolicitacao  @default(PENDENTE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  materia Materia @relation(fields: [materiaId], references: [id], onDelete: Cascade)

  @@unique([userId, materiaId])
  @@map("solicitacoes_materias")
}

enum StatusSolicitacao {
  PENDENTE
  APROVADA
  REJEITADA
}

// ─────────────────────────────────────────────
// RESPOSTA DE QUIZ — última resposta do usuário por questão
// ─────────────────────────────────────────────
model RespostaQuiz {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  opcaoId   String   // opção escolhida
  correta   Boolean  // denormalizado para queries rápidas
  topicoId  String   // denormalizado para agrupamento por tópico
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])   // upsert: uma resposta por questão por usuário
  @@map("respostas_quiz")
}

// ─────────────────────────────────────────────
// REVISÃO DE FLASHCARD — se o usuário soube ou não
// ─────────────────────────────────────────────
model RevisaoFlashcard {
  id          String   @id @default(cuid())
  userId      String
  flashcardId String
  acertou     Boolean  // true = "Sabia", false = "Não sabia"
  topicoId    String   // denormalizado
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
  @@map("revisoes_flashcard")
}
